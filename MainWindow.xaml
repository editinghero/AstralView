<Window
    x:Class="AstralView.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:AstralView.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid ColumnDefinitions="*,*">
            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,80">
                    <StackPanel Padding="16" Spacing="20">
                        <StackPanel Spacing="2" Margin="0,12,0,0">
                            <TextBlock Text="AstralView" Style="{StaticResource TitleTextBlockStyle}" />
                            <TextBlock Text="scrcpy controller" Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        <ui:DevicePanel x:Name="DevicePanelControl" />
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        
                        <StackPanel Spacing="12">
                            <TextBlock Text="Wireless" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBox x:Name="IpAddressBox" PlaceholderText="192.168.x.x" Header="IP Address" />
                            <TextBox x:Name="PortBox" PlaceholderText="5555" Header="Port (optional)" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Content="Connect" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Click="WirelessConnect_Click" />
                                <Button Grid.Column="1" Content="Disconnect" HorizontalAlignment="Stretch" Click="WirelessDisconnect_Click" />
                            </Grid>
                            <TextBlock x:Name="WirelessStatusText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        <ui:VideoPanel x:Name="VideoPanelControl" />
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        <ui:CameraPanel x:Name="CameraPanelControl" />
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        <ui:AudioPanel x:Name="AudioPanelControl" />
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />

                        <StackPanel Spacing="8">
                            <TextBlock Text="Window" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <CheckBox x:Name="FullscreenCheck" Content="Fullscreen" />
                            <CheckBox x:Name="AlwaysOnTopCheck" Content="Always on Top" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Recording" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch x:Name="RecordToggle" Grid.Column="1" OnContent="" OffContent="" />
                            </Grid>
                            <TextBox x:Name="RecordFileBox" PlaceholderText="record.mp4" Header="Output file" />
                            <Button x:Name="BrowseFileButton" Content="Browse..." HorizontalAlignment="Stretch" Click="BrowseFile_Click" />
                        </StackPanel>
                        
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Shortcuts" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ListView x:Name="ShortcutsListView" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Padding="0,6">
                                            <TextBlock Grid.Column="0" Text="{Binding Action}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1" Text="{Binding Shortcut}" Opacity="0.7" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Device Actions" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <Button Content="Turn Screen Off" HorizontalAlignment="Stretch" Click="TurnScreenOff_Click" />
                            <Button Content="Turn Screen On" HorizontalAlignment="Stretch" Click="TurnScreenOn_Click" />
                            <Button Content="Show Touches" HorizontalAlignment="Stretch" Click="ShowTouches_Click" />
                            <Button Content="Stay Awake" HorizontalAlignment="Stretch" Click="StayAwake_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="600" Padding="20">
                    <TextBlock Text="Command Preview" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" Opacity="0.5" />
                    <TextBox x:Name="CommandPreviewText" 
                             FontFamily="Cascadia Code, Consolas" 
                             FontSize="12" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             Height="120"
                             IsReadOnly="False" />
                </StackPanel>

                <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <TextBlock x:Name="StatusBarText" Grid.Column="0" VerticalAlignment="Center" Text="Ready" Opacity="0.7" />
                        <Button x:Name="StopButton" Grid.Column="1" Content="Stop" IsEnabled="False" Click="StopButton_Click" />
                        <Button x:Name="StartButton" Grid.Column="2" Content="Start scrcpy" Style="{StaticResource AccentButtonStyle}" MinWidth="140" Click="StartButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
