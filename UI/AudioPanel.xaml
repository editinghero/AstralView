<UserControl
    x:Class="AstralView.AudioPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="🎤 Audio" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ToggleSwitch x:Name="AudioToggle" Grid.Column="1"
                          IsOn="True"
                          Toggled="AudioToggle_Toggled"
                          OnContent="" OffContent="" />
        </Grid>

        <StackPanel x:Name="AudioOptions" Spacing="10">
            <TextBlock Text="Audio Source" />
            <ComboBox x:Name="AudioSourceCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="AudioSourceCombo_SelectionChanged">
                <ComboBoxItem Content="Device output" IsSelected="True"/>
                <ComboBoxItem Content="Microphone"/>
            </ComboBox>
        </StackPanel>
    </StackPanel>
</UserControl>
