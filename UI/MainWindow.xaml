<Window
    x:Class="AstralView.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:AstralView.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Main layout: Sidebar + Content -->
        <Grid ColumnDefinitions="260,*">

            <!-- ====== LEFT SIDEBAR ====== -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,80">
                    <StackPanel Padding="16" Spacing="20">

                        <!-- App Title -->
                        <StackPanel Spacing="2" Margin="0,12,0,0">
                            <TextBlock Text="AstralView" Style="{StaticResource TitleTextBlockStyle}" />
                            <TextBlock Text="scrcpy controller" Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <NavigationViewItemSeparator />

                        <!-- Device Panel -->
                        <ui:DevicePanel x:Name="DevicePanelControl" />

                        <NavigationViewItemSeparator />

                        <!-- Video Panel -->
                        <ui:VideoPanel x:Name="VideoPanelControl" />

                        <NavigationViewItemSeparator />

                        <!-- Camera Panel -->
                        <ui:CameraPanel x:Name="CameraPanelControl" />

                        <NavigationViewItemSeparator />

                        <!-- Audio Panel -->
                        <ui:AudioPanel x:Name="AudioPanelControl" />

                        <NavigationViewItemSeparator />

                        <!-- Wireless Connect -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="📡 Wireless" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBox x:Name="IpAddressBox"
                                     PlaceholderText="192.168.x.x"
                                     Header="IP Address" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Content="Connect"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="WirelessConnect_Click" />
                                <Button Grid.Column="1"
                                        Content="Disconnect"
                                        HorizontalAlignment="Stretch"
                                        Click="WirelessDisconnect_Click" />
                            </Grid>
                            <TextBlock x:Name="WirelessStatusText"
                                       FontSize="12"
                                       Opacity="0.7"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <NavigationViewItemSeparator />

                        <!-- Presets -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="⚡ Presets" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <Button Grid.Row="0" Grid.Column="0" Content="🎮 Gaming" HorizontalAlignment="Stretch" Tag="Gaming" Click="Preset_Click"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="🎬 Record" HorizontalAlignment="Stretch" Tag="Recording" Click="Preset_Click"/>
                                <Button Grid.Row="1" Grid.Column="0" Content="📡 Stream" HorizontalAlignment="Stretch" Tag="Streaming" Click="Preset_Click"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="📶 Low BW" HorizontalAlignment="Stretch" Tag="LowBandwidth" Click="Preset_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Window Options -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="🖥️ Window" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <CheckBox x:Name="FullscreenCheck" Content="Fullscreen" />
                            <CheckBox x:Name="AlwaysOnTopCheck" Content="Always on Top" />
                        </StackPanel>

                        <!-- Recording -->
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="⏺ Recording" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch x:Name="RecordToggle" Grid.Column="1" OnContent="" OffContent="" />
                            </Grid>
                            <TextBox x:Name="RecordFileBox"
                                     PlaceholderText="record.mp4"
                                     Header="Output file" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ====== RIGHT CONTENT AREA ====== -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">

                <!-- Empty state / info -->
                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <FontIcon Glyph="&#xE70A;"
                              FontSize="64"
                              Opacity="0.3" />
                    <TextBlock Text="Configure and start scrcpy"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Opacity="0.5" />
                    <TextBlock x:Name="CommandPreviewText"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="12"
                               Opacity="0.6"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="500"
                               Text="Command will appear here..." />
                </StackPanel>

                <!-- Status bar + Start button -->
                <Border Grid.Row="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <TextBlock x:Name="StatusBarText"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="Ready"
                                   Opacity="0.7" />

                        <Button x:Name="StopButton"
                                Grid.Column="1"
                                Content="Stop"
                                IsEnabled="False"
                                Click="StopButton_Click" />

                        <Button x:Name="StartButton"
                                Grid.Column="2"
                                Content="▶  Start scrcpy"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="140"
                                Click="StartButton_Click" />
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
