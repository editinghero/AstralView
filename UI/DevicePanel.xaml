<UserControl
    x:Class="AstralView.UI.DevicePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <TextBlock Text="📱 Device" Style="{StaticResource SubtitleTextBlockStyle}" />

        <Grid ColumnDefinitions="*,Auto,Auto">
            <ComboBox x:Name="DeviceComboBox"
                      Grid.Column="0"
                      PlaceholderText="Select a device..."
                      HorizontalAlignment="Stretch"
                      SelectionChanged="DeviceComboBox_SelectionChanged" />

            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Content="&#xE72C;"
                    FontFamily="Segoe Fluent Icons"
                    Margin="8,0,0,0"
                    ToolTipService.ToolTip="Refresh devices"
                    Click="RefreshButton_Click" />

            <TextBlock x:Name="DeviceStatusText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                       FontSize="12" />
        </Grid>
    </StackPanel>
</UserControl>
