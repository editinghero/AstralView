<UserControl
    x:Class="AstralView.UI.CameraPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="📷 Camera" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ToggleSwitch x:Name="CameraToggle" Grid.Column="1"
                          Toggled="CameraToggle_Toggled"
                          OnContent="" OffContent="" />
        </Grid>

        <StackPanel x:Name="CameraOptions" IsEnabled="False" Spacing="10">
            <StackPanel Spacing="4">
                <TextBlock Text="Facing" />
                <ComboBox x:Name="FacingCombo" HorizontalAlignment="Stretch"
                          SelectionChanged="FacingCombo_SelectionChanged">
                    <ComboBoxItem Content="Back" IsSelected="True"/>
                    <ComboBoxItem Content="Front"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Camera Size" />
                <ComboBox x:Name="CameraSizeCombo" HorizontalAlignment="Stretch"
                          SelectionChanged="CameraSizeCombo_SelectionChanged">
                    <ComboBoxItem Content="1920x1080" IsSelected="True"/>
                    <ComboBoxItem Content="1280x720"/>
                    <ComboBoxItem Content="640x480"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Camera ID (optional)" />
                <TextBox x:Name="CameraIdBox" PlaceholderText="e.g. 0"
                         TextChanged="CameraIdBox_TextChanged" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
